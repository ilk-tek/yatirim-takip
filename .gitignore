# ==========================================
# YATIRIM TAKİP — .gitignore
# ==========================================

# Sanal ortam (her bilgisayarda ayrı kurulur, GitHub'a gerek yok)
.venv/
venvs/

# Gizli bilgiler — TURSO token'ı burada, KESİNLİKLE paylaşılmamalı
.env
TURSO_INFO/

# Python derleme dosyaları
__pycache__/
*.pyc

# Yerel veritabanı dosyaları (artık Turso'da, GitHub'a gerek yok)
*.db
*.db-journal

# Streamlit yerel ayarları
.streamlit/

# macOS sistem dosyaları
.DS_Store

# pyenv yerel sürüm dosyası (her bilgisayarda farklı olabilir)
.python-version

# VS Code kişisel ayarları (her bilgisayarda ayrı kalmalı)
.vscode/

# nano/editör yedek dosyaları
*.save
